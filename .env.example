# PostgreSQL Connection (Option 1: Individual variables)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=your_database_name

# If DB_NAME is set, pgshell connects directly to that database (skips selection)
# First-time: password is saved in OS keychain (Windows Credential Manager / macOS Keychain / Linux Secret Service)

# PostgreSQL Connection (Option 2: Single URL - overrides above if both exist)
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
