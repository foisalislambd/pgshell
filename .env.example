# Project database name (used even when login uses saved system credentials)
DB_NAME=your_database_name

# Optional: try these first for login. If they fail, PgShell falls back to
# OS keychain credentials saved on first interactive setup — and still uses DB_NAME above.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here

# First-time (no keychain yet): run `pgshell` and enter credentials when prompted.
# Password is stored in OS keychain (Windows Credential Manager / macOS Keychain / Linux Secret Service).

# Option: single URL (overrides individual vars if both exist)
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
