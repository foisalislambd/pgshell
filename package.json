{
  "name": "pgshell",
  "version": "1.0.9",
  "description": "All-in-one powerful and human-friendly PostgreSQL CLI manager",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "pgshell": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "postgresql",
    "cli",
    "tui",
    "manager",
    "database"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Foisalislambd/pgshell.git"
  },
  "homepage": "https://foisalislambd.github.io/pgshell/",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cross-keychain": "^1.1.0",
    "dotenv": "^17.4.2",
    "fzf": "^0.5.2",
    "gradient-string": "^3.0.0",
    "ora": "^9.4.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
