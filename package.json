{
  "name": "pgshell",
  "version": "1.1.0",
  "description": "All-in-one powerful and human-friendly PostgreSQL CLI manager",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "pgshell": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "keywords": [
    "postgresql",
    "postgres",
    "cli",
    "tui",
    "database",
    "sql",
    "psql",
    "pg"
  ],
  "author": {
    "name": "Foisal Islam",
    "url": "https://github.com/Foisalislambd"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Foisalislambd/pgshell.git"
  },
  "bugs": {
    "url": "https://github.com/Foisalislambd/pgshell/issues"
  },
  "homepage": "https://foisalislambd.github.io/pgshell/",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    ".env.example"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cross-keychain": "^1.1.0",
    "dotenv": "^17.4.2",
    "fzf": "^0.5.2",
    "gradient-string": "^3.0.0",
    "ora": "^9.4.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
